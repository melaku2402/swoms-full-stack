# Backend environment example
# Copy this file to `.env` and fill with real values.

PORT=4000
NODE_ENV=development

# Database (adjust according to the adapter used in `src/config/database.js`)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=swoms_db

# JWT secret
JWT_SECRET=change_this_to_a_secure_random_value

# Optional: external services
#SMTP_HOST=
#SMTP_PORT=
#SMTP_USER=
#SMTP_PASS=
